<clickhouse>
    <users>
        <!-- User admin: buat operasi DDL (create table, dll) -->
        <default>
            <password>admin123</password>
            <access_management>1</access_management>
            <networks>
                <ip>::/0</ip>
            </networks>
        </default>

        <!-- User khusus Superset: READ ONLY -->
        <superset_user>
            <password>superset_pass</password>
            <networks>
                <ip>::/0</ip>
            </networks>
            <profile>readonly</profile>
        </superset_user>
    </users>

    <!-- Profile readonly: cuma boleh SELECT -->
    <profiles>
        <readonly>
            <readonly>2</readonly>
            <!--
                readonly=1 → hanya SELECT
                readonly=2 → SELECT + SETTINGS (buat Superset butuh ini)
            -->
        </readonly>
    </profiles>
</clickhouse>
